---
import { T } from '../data/content.js';
const t = T.en;
const WHATSAPP = 'https://api.whatsapp.com/send?phone=573058602613';
const GITHUB = 'https://github.com/diegoALCE95';
const LINKEDIN = 'https://www.linkedin.com/in/diegoalce/';
---

