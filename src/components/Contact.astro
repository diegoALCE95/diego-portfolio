  <div class="contact__container">
    <div class="contact__inner">
      <div class="contact__eyebrow">// <span data-i18n="contactEyebrow">{t.contactEyebrow}</span></div>
      <h2 class="contact__h2" data-i18n="contactHeading">{t.contactHeading}</h2>
      <p class="contact__sub" data-i18n="contactSub">{t.contactSub}</p>

      <a class="contact__cta" href={WHATSAPP} target="_blank" rel="noopener noreferrer" data-i18n="contactCta">{t.contactCta}</a>

      <div class="socials">
        <a class="social" href={GITHUB} target="_blank" rel="noopener noreferrer">
